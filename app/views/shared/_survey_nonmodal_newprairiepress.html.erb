<!-- survey -->
<div id="surveyNonModalNewPrairiePress" class="alert survey" role="alert" aria-labelledby="surveyNonModalLabel" style="display:none;">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">        
        <h4 class="modal-title" id="surveyNonModalLabel">Share the story of what Open Access means to you</h4>
        <button type="button" class="close" data-dismiss="alert" aria-label="Close" onclick="survey_button_no()">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <%= image_tag 'oa-lock-logo-lg.png', alt: 'a graphic of a lock that is open, the universal logo for open access'  %>
        <p>New Prairie Press needs your feedback to better understand how readers are using openly available ebooks. You can help by taking a short, privacy-friendly survey.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary btn-lg" data-dismiss="alert" onclick="survey_button_yes()">Yes, I can help</button>
        <button type="button" class="btn btn-default btn-lg" data-dismiss="alert" onclick="survey_button_no()">No thanks</button>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript">
  function survey_button_yes(){
    Cookies.set('survey_newprairiepress', 'clicked', { expires: 365<%= ', secure: true' if Rails.env == 'production' %> });
    window.open("<%= j("https://umich.qualtrics.com/jfe/form/SV_0pN4FLqYb5Y2U3I?publisher=#{ERB::Util.url_encode(@subdomain.to_s)}&title=#{ERB::Util.url_encode(@parent_presenter.page_title.to_s)}") %>", "_blank");
  }
  function survey_button_no(){
    Cookies.set('survey_newprairiepress', 'ignore', { expires: 180<%= ', secure: true' if Rails.env == 'production' %> });
  }
</script>
