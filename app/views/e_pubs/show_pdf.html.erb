<% provide :page_title, @title || "Title" %>
<%# https://github.com/mlibrary/heliotrope/issues/1228 %>
<% content_for :head do %>
  <meta name="turbolinks-cache-control" content="no-cache">
  <%# Altmetric badge JS %>
  <script type="text/javascript" src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"></script>
  <% if @parent_presenter.doi.present? %>
    <%# Dimensions badge JS %>
    <script async src="https://badge.dimensions.ai/badge.js" charset="utf-8"></script>
  <% end %>

  <meta name="viewport" content="width=device-width">
  <meta name="google" content="notranslate">

  <%# pdf.mjs is NOT loaded in the parent document — the iframe loads its own copy.
      A second parent-side pdf.mjs was removed to prevent GlobalWorkerOptions conflicts.
      Any pdf.js APIs needed are obtained via iframe.contentWindow.PDFViewerApplication. %>

  <% if defined? @subdomain %>
    <% if @parent_presenter.use_hypothesis? %>
      <!-- hypothes.is -->
      <script type="text/javascript">
        window.hypothesisConfig = function () {
          return {
            openSidebar: false,
            theme: 'clean',
            enableMultiFrameSupport: true,
            onLayoutChange: function(state) {
              var $frame = $('.annotator-frame');
              var $reader = $("#reader");
            },
            enableExperimentalNewNoteButton: true
          };
        };
      </script>
      <script src="https://cdn.hypothes.is/hypothesis"></script>
    <% end %>
  <% end %>

<% end %>

<% provide :body do %>
  <% if defined? @presenter.file_set_coins_title %>
    <span class="Z3988" title="<%= @presenter.file_set_coins_title %>" aria-hidden="true"></span>
  <% end %>

  <%= render partial: "survey_oa" %>

  <div class="skip"></div>
  <div id="pdfLoadingProgressBar" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

  <% if @parent_presenter.use_hypothesis? %>
    <%#
      Hidden proxy trigger for the Hypothesis sidebar.

      The Hypothesis client (v1.17xx, the Preact `sidebar.tsx` rewrite) scans the
      DOM for elements carrying `data-hypothesis-trigger` exactly ONCE, when its
      sidebar host boots, and binds a click listener to each match. Our cozy
      toolbar annotation button is created asynchronously (after reader init) and
      is usually NOT in the DOM yet at that moment — especially on fast/production
      loads and in Firefox — so a listener never gets attached to it and the button
      appears dead. (The legacy `.annotator-frame` / `annotator-collapsed` class it
      also toggled no longer exists in the light DOM in this client version.)

      This element is server-rendered, so it is guaranteed to be present before
      Hypothesis boots; Hypothesis binds its handler to THIS element, and the
      visible toolbar button simply forwards its clicks here via `.click()`,
      invoking the exact same supported open/toggle code path. It is visually
      hidden but must remain in the layout (not `display:none`) and focus-inert.
    %>
    <button id="hypothesisProxyTrigger"
            data-hypothesis-trigger
            type="button"
            aria-hidden="true"
            tabindex="-1"
            style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;"></button>
  <% end %>

  <%= tag.div id: 'epub', class: press_presenter.present? ? press_presenter.press_subdomains : '' do %>
    <div id="reader">
      <div id="mainContainer"></div>
    </div>
  <% end %>

  <script type="module">
    // pdf.js 6.1.200 iframe-based viewer

    <% if @parent_presenter.use_hypothesis? %>
      // Custom annotator toolbar button.
      //
      // The Hypothesis client (v1.17xx) scans the DOM for [data-hypothesis-trigger]
      // elements exactly ONCE when its sidebar boots and binds a click listener to
      // each. This cozy control is added asynchronously (after reader init) and is
      // usually not in the DOM yet at that moment on fast/production loads — worst in
      // Firefox — so a listener was never attached to it and clicks did nothing.
      //
      // Fix: forward clicks to a server-rendered hidden #hypothesisProxyTrigger that
      // IS present before Hypothesis boots, so Hypothesis binds to it reliably. The
      // trigger opens the sidebar; Hypothesis provides its own in-sidebar control to
      // close it (the trigger is open-only, so we don't try to close from here).
      var AnnotationTool = cozy.Control.Widget.Toggle.extend({
        defaultTemplate: '<button class="button--sm annotation" data-toggle="button" aria-label="Open Annotations"><i class="fa fa-pencil" title="Open annotation panel" aria-hidden="true"></i></button><div class="annotation-count" data-hypothesis-annotation-count></div>',

        initialize: function(options) {
          cozy.Control.Widget.Toggle.prototype.initialize.apply(this, arguments);

          // Both states open the sidebar: the proxy trigger is open-only, so there is
          // no reliable close path from here to hang off the second state.
          this.options.states = [{
            stateName: 'close-annotator',
            onClick: this.openAnnotator.bind(this)
          },
          {
            stateName: 'open-annotator',
            onClick: this.openAnnotator.bind(this)
          }];
        },

        openAnnotator: function(self, reader) {
          var proxy = document.getElementById('hypothesisProxyTrigger');
          if (!proxy) { return; }
          proxy.click();
          self.state('open-annotator');
        }
      })
    <% end %>

    // PDF Scale preferences
    cozy.Control.Preferences.fieldset.PDFScale = cozy.Control.Preferences.fieldset.Scale.extend({
      options: {},

      intialize: function(control, options) {
        cozy.Control.Preferences.fieldset.Scale.prototype.onAdd.apply(this, arguments);
      },

      initializeForm: function(form) {
        if ( ! this._inputs ) {
          this._inputs = form.querySelector('#x' + this._id + '-list');
          this._actionReset = form.querySelector('#x' + this._id + '-reset');
          this._actionReset.addEventListener('click', function(event) {
            event.preventDefault();
            this._inputs.querySelector('input[value="auto"]').checked = true;
            this._updatePreview();
          }.bind(this));
        }

        this._preview = form.querySelector(`#x${this._id}-preview > div`);

        var currentScale = this._control._reader.options.scale || 'auto';
        if (this._inputs.querySelector('input[value="' + currentScale + '"]')) {
          this._inputs.querySelector('input[value="' + currentScale + '"]').checked = true;
        }
        this._current.scale = currentScale;

        this._inputs.addEventListener('change', function(event) {
          var target = event.target;
          if ( target.tagName == 'INPUT' ) {
            this._updatePreview();
          }
        }.bind(this));

        this._updatePreview();
      },

      updateForm: function(form, options, saveable) {
        var current = this._inputs.querySelector('input:checked') ? this._inputs.querySelector('input:checked').value : 'auto';
        options.scale = saveable.scale = current;
      },

      _updatePreview: function() {
        var current = this._inputs.querySelector('input:checked') ? this._inputs.querySelector('input:checked').value : 'auto';
        var scale = ( parseFloat(current, 10) );
        if ( isNaN(scale) ) {
          scale = '1.0';
        }
        this._preview.parentNode.dataset.scale = current;
        this._preview.style.transform = "scale(" + scale + ")";
      },

      template: function() {
        var html = '<fieldset class="cozy-fieldset-pdf-scale">' +
          '<legend>Zoom In/Out</legend>' +
          '<style>' +
            '.cozy-fieldset-pdf-scale label { margin: 0.5 0 !important; }' +
            '.cozy-fieldset-pdf-scale .preview--text_size[data-scale="auto"] { height: auto; }' +
            '.cozy-fieldset-pdf-scale .preview--text_size[data-scale="page-fit"] { height: auto; width: 60%; }' +
            '.cozy-fieldset-pdf-scale .preview--text_size[data-scale="page-width"] { width: 60%; }' +
            '.cozy-fieldset-pdf-scale .preview--text_size[data-scale="page-actual"] > div { width: 150%; transform: scale(1.5) !important; }' +
          '</style>' +
          '<div class="preview--text_size" id="x${this._id}-preview">' +
            '<div style="transform-origin: top left">' +
              '"Yes, that\'s it," said the Hatter with a sigh: "it\'s always tea-time, and we\'ve no time to wash the things between whiles."' +
            '</div>' +
          '</div>' +
          '<ul id="x${this._id}-list" style="margin-top: 1rem">' +
            '<li><label><input type="radio" name="scaleSelect" value="auto" /> Automatic Zoom</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="page-actual" /> Actual Size</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="page-fit" /> Page Fit</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="page-width" /> Page Width</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="0.5" /> 50%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="0.75" /> 75%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="1" /> 100%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="1.25" /> 125%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="1.5" /> 150%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="2" /> 200%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="3" /> 300%</label></li>' +
            '<li><label><input type="radio" name="scaleSelect" value="4" /> 400%</label></li>' +
          '</ul>' +
          '<p style="margin-top: 1.5rem">' +
            '<button id="x${this._id}-reset" class="reset button--inline" style="margin-left: 8px">Reset</button>' +
          '</p>' +
        '</fieldset>';
        return html.replace(/\$\{this._id\}/g, this._id);
      }
    });

    cozy.Control.Preferences.prototype._createPanel = function() {
      var self = this;
      if ( this._modal._container.querySelector('form') ) { return; }

      var template = '';
      var possible_fieldsets = [];
      possible_fieldsets.push('PDFScale');
      this._fieldsets = [];
      possible_fieldsets.forEach(function(cls) {
        var fieldset = new cozy.Control.Preferences.fieldset[cls](this);
        template += fieldset.template();
        this._fieldsets.push(fieldset);
      }.bind(this));

      template = '<form>' + template + '</form>';

      this._modal._container.querySelector('main').innerHTML = template;
      this._form = this._modal._container.querySelector('form');
    };

    var PDFPreferences = cozy.Control.Preferences.extend({
      EOT: true
    });

    // PDF Navigator
    var PDFNavigator = cozy.Control.Navigator.extend({
      EOT: true
    });

    // PDF Search
    var PDFSearch = cozy.Control.Search.extend({

      onAdd: function(reader) {
        var self = this;
        this._reader.on('ready', function() {
          this._reader.PDFViewerApplication.eventBus.on('updatefindmatchescount', this._waitForResults.bind(this));
          this._reader.PDFViewerApplication.eventBus.on('updatefindcontrolstate', this._waitForQuery.bind(this));
        }.bind(this));

        return cozy.Control.Search.prototype.onAdd.apply(this, arguments);
      },

      submitQuery: function() {
        // pdf.js 6.1.200 viewer.mjs: phraseSearch was removed; matchDiacritics added.
        // FindState enum: FOUND=0, NOT_FOUND=1, WRAPPED=2, PENDING=3 (same as 5.x).
        this._doWaitForResults = false;
        this._reader.PDFViewerApplication.eventBus.dispatch('find', {
          source: this._reader,
          type: 'find',
          query: this.searchString,
          caseSensitive: false,
          matchDiacritics: false,
          entireWord: false,
          highlightAll: true,
          findPrevious: null
        })
      },

      _waitForQuery: function(argv) {
        if ( argv.state == 0 || argv.state == 2 ) {
          this._doWaitForResults = true;
        } else if ( argv.state == 1 ) {
          this._data = { highlight_off: "yes", search_results: [] };
          this._buildResults();
        }
      },

      _waitForResults: function(argv) {
        if ( ! this._doWaitForResults ) { return; }
        if ( this.searchTimer ) { clearTimeout(this.searchTimer); }
        this.searchTimer = setTimeout(this._gatherResults.bind(this), 500);
      },

      _gatherResults: function() {
        var self = this;

        this._data = { search_results: [], highlight_off: 'yes' };
        var pdfViewer = this._reader.pdfViewer;
        var findController = this._reader.PDFViewerApplication.findController;

        // pdf.js 6.1.200 viewer.mjs: findController.pageMatches is a public getter (line ~12393).
        // _pageContents remains a regular underscore-prefixed field (not ES #private), still accessible.
        var allPageMatches = findController.pageMatches || [];
        for(var i = 0; i < pdfViewer.pagesCount; i++) {
          var matches = allPageMatches[i];
          if ( ! matches ) { continue ; }
          var text = (findController._pageContents && findController._pageContents[i]) || '';
          matches.forEach(function(match, index) {
            var snippet = self._getMatch(text, self.searchString, match);
            self._data.search_results.push({ cfi: 'page=' + ( i + 1 ), matchIdx: match, snippet: snippet });
          })
        }

        this._buildResults();
      },

      _getMatch: function(string, term, index) {
        if(index >= 0) {
          var _ws = [" ","\t"];
          var whitespace = 0;
          var rightLimit = 0;
          var leftLimit = 0;
          var whitespaceLimit = 8;

          for(rightLimit = index + term.length; whitespace < whitespaceLimit; rightLimit++) {
            if(rightLimit >= string.length){break}
            if(_ws.indexOf(string.charAt(rightLimit)) >= 0){whitespace += 1}
          }

          whitespace = 0;
          for(leftLimit = index; whitespace < whitespaceLimit; leftLimit--) {
            if(leftLimit < 0){break}
            if(_ws.indexOf(string.charAt(leftLimit)) >= 0){whitespace += 1}
          }

          var snippet = string.substr(leftLimit + 1, rightLimit - leftLimit - 1).replace(/([\.\;\,])(\w)/g, '$1 $2');
          snippet = snippet.replace(/([a-z])([A-Z])/g, '$1 $2');
          snippet = snippet.replace(/([a-z])(\d+)([a-z])/gi, '$1 $2 $3');
          snippet = snippet.replace(/[^ -~]+/g, "");
          return snippet;
        }
        return
      },

      EOT: true
    });

    // PDF Contents/Sidebar
    var PDFContents = cozy.Control.Contents.extend({
      _bindEvents: function() {
        var self = this;

        this._control.setAttribute('id', 'sidebarToggle');

        // pdf.js 6.1.200 viewer.html: sidebar is now inside #viewsManager; outline is #outlinesView,
        // thumbnails are #thumbnailsView (both inside #viewsManagerContent). The parent modal
        // keeps its own local IDs (#outlineView, #thumbnailView) — _copySidebarFromIframe maps between them.
        // note that button--lg is added to viewThumbnail, viewOutline, and viewAttachments to allow them to
        // inherit some press-specific stuff from themes.scss.
        <% if @parent_presenter.pdf_ebook_presenter.intervals? %>
          var template =
            '<div id="toolbarSidebar">' +
              '<div class="splitToolbarButton toggled">' +
                '<button id="viewOutline" class="toolbarButton toggled button--lg" title="Show Table of Contents (double-click to expand/collapse all items)" tabindex="0">Table of Contents</button>' +
                '<button id="viewThumbnail" class="toolbarButton button--lg" title="Show Thumbnails" tabindex="0">Thumbnails</button>' +
                '<button id="viewAttachments" class="toolbarButton button--lg" title="Show Attachments" tabindex="0">Attachments</button>' +
              '</div>' +
            '</div>' +
            '<div id="sidebarContent">' +
              '<div id="outlineView" class="treeView"></div>' +
              '<div id="thumbnailView" class="hidden"></div>' +
              '<div id="attachmentsView" class="hidden"></div>' +
            '</div>';
        <% else %>
          var template =
            '<div id="toolbarSidebar">' +
              '<div class="splitToolbarButton toggled hidden button--lg">' +
                '<button id="viewOutline" class="toolbarButton" title="Show Table of Contents (double-click to expand/collapse all items)" tabindex="0">Table of Contents</button>' +
                '<button id="viewThumbnail" class="toolbarButton toggled" title="Show Thumbnails" tabindex="0">Thumbnails</button>' +
                '<button id="viewAttachments" class="toolbarButton" title="Show Attachments" tabindex="0">Attachments</button>' +
              '</div>' +
            '</div>' +
            '<div id="sidebarContent">' +
              '<div id="outlineView" class="treeView hidden"></div>' +
              '<div id="thumbnailView"></div>' +
              '<div id="attachmentsView" class="hidden"></div>' +
            '</div>';
        <% end %>

        this._modal = this._reader.modal({
          template: template,
          title: 'Contents',
          region: 'left',
          className: 'cozy-modal-contents',
          callbacks: {
            onShow: function() {
              self._copySidebarFromIframe();
            },
            onClose: function() {
              // Clean up if needed
            }
          }
        });

        this._modal._container.querySelector('.modal__content').setAttribute('id', 'sidebarContainer');

        this._reader.on('updateContents', function(data) {
          this._pdfSidebar = this._reader.PDFViewerApplication.pdfSidebar;

          $(this._control).on('click', function(event) {
            self._reader.tracking.action('contents/open');
            self._modal.activate();
          });
        }.bind(this));
      },

      _copySidebarFromIframe: function() {
        var self = this;

        if (!this._reader.PDFViewerApplication) {
          return;
        }

        try {
          var iframeDoc = this._reader._iframe.contentDocument || this._reader._iframe.contentWindow.document;

          // Copy relevant CSS from iframe to modal (one time only)
          if (!this._stylesCopied) {
            this._copySidebarStyles(iframeDoc);
            this._stylesCopied = true;
          }

          // pdf.js 6.1.200 viewer.html: outline is #outlinesView (with 's')
          // inside #viewsManagerContent. Parent modal keeps local ID #outlineView.
          var iframeOutlineView = iframeDoc.querySelector('#outlinesView') || iframeDoc.querySelector('#outlineView');

          // Get modal's containers
          var modalOutlineView = this._modal._container.querySelector('#outlineView');
          var modalThumbnailView = this._modal._container.querySelector('#thumbnailView');

          if (iframeOutlineView && modalOutlineView) {
            modalOutlineView.innerHTML = iframeOutlineView.innerHTML;
            this._wireOutlineClicks(modalOutlineView);
          }

          // Thumbnails: do NOT copy from the iframe's hidden #thumbnailsView —
          // #viewsManager is display:none in the iframe so pdf.js never renders any
          // thumbnail images (getVisibleThumbs() always returns nothing). Instead we
          // render thumbnails directly from the PDF document when the tab is shown.
          if (modalThumbnailView && !modalThumbnailView.classList.contains('hidden')) {
            // Thumbnail tab is the default active view — start rendering right away.
            if (!self._thumbnailsRendered) {
              self._thumbnailsRendered = true;
              self._renderThumbnailsDirect(modalThumbnailView);
            }
          }

          this._setupViewButtons();

        } catch (e) {
          console.error("PDF reader: Error copying sidebar:", e);
        }
      },

      // Render all page thumbnails directly from the PDF document.
      // This bypasses the iframe's hidden sidebar (which pdf.js never populates because
      // #viewsManager is display:none) and uses pdfDocument.getPage() + page.render()
      // to paint each thumbnail to a canvas, then sets the img src from the data URL.
      _renderThumbnailsDirect: function(thumbnailView) {
        var self = this;
        var app = self._reader.PDFViewerApplication;

        if (!app || !app.pdfDocument) {
          // Not ready yet — retry shortly
          setTimeout(function() {
            self._thumbnailsRendered = false;
            self._renderThumbnailsDirect(thumbnailView);
          }, 300);
          return;
        }

        var pdfDocument = app.pdfDocument;
        var totalPages = app.pagesCount;
        var THUMB_WIDTH = 126; // matches THUMBNAIL_WIDTH in pdf.js

        thumbnailView.innerHTML = '';

        // Build placeholder divs for every page up-front so the scroll area has
        // the correct height and the user can see progress as thumbnails render.
        var renderItems = [];
        for (var p = 1; p <= totalPages; p++) {
          var thumbDiv = document.createElement('div');
          thumbDiv.className = 'thumbnail';
          thumbDiv.setAttribute('page-number', String(p));

          var imageContainer = document.createElement('div');
          imageContainer.className = 'thumbnailImageContainer missingThumbnailImage';
          imageContainer.setAttribute('role', 'button');
          imageContainer.setAttribute('tabindex', '-1');
          imageContainer.setAttribute('page-number', String(p));

          var img = document.createElement('img');
          img.alt = 'Page ' + p;
          imageContainer.appendChild(img);
          thumbDiv.appendChild(imageContainer);
          thumbnailView.appendChild(thumbDiv);

          renderItems.push({ pageNum: p, img: img, imageContainer: imageContainer });
        }

        self._wireThumbnailClicks(thumbnailView);

        // Render pages one at a time, yielding between each so the UI stays
        // responsive. Rendering at 2× the display size gives crisp thumbnails.
        var renderIndex = 0;

        function renderNext() {
          if (renderIndex >= renderItems.length) return;

          var item = renderItems[renderIndex++];

          pdfDocument.getPage(item.pageNum).then(function(pdfPage) {
            var viewport = pdfPage.getViewport({ scale: 1 });
            var scale = (THUMB_WIDTH * 2) / viewport.width;
            var scaledViewport = pdfPage.getViewport({ scale: scale });

            var canvas = document.createElement('canvas');
            canvas.width = Math.floor(scaledViewport.width);
            canvas.height = Math.floor(scaledViewport.height);

            var ctx = canvas.getContext('2d');
            return pdfPage.render({
              canvasContext: ctx,
              viewport: scaledViewport
            }).promise.then(function() {
              item.img.src = canvas.toDataURL('image/jpeg', 0.75);
              item.imageContainer.style.height = Math.floor(canvas.height / 2) + 'px';
              item.imageContainer.classList.remove('missingThumbnailImage');
              // Free the temporary canvas memory
              canvas.width = 0;
              canvas.height = 0;
            });
          }).catch(function() {
            // Leave the placeholder visible if the page fails to render
          }).then(function() {
            // Yield to the browser event loop before the next page
            setTimeout(renderNext, 0);
          });
        }

        renderNext();
      },

      _copySidebarStyles: function(iframeDoc) {
        try {
          // Find viewer.css in the iframe and copy rules relevant to sidebar content.
          // pdf.js 6.1.200: selectors use #outlinesView and #thumbnailsView (with 's').
          var stylesheets = iframeDoc.styleSheets;
          var viewerCSS = '';

          for (var i = 0; i < stylesheets.length; i++) {
            var sheet = stylesheets[i];
            if (sheet.href && sheet.href.indexOf('viewer.css') > -1) {
              try {
                var rules = sheet.cssRules || sheet.rules;
                for (var j = 0; j < rules.length; j++) {
                  var rule = rules[j];
                  var text = rule.cssText;

                  // Match both 5.x (#outlineView) and 6.x (#outlinesView) selector names.
                  // Do NOT copy #sidebarContent rules — the iframe uses position:absolute which
                  // breaks the parent flex layout; cozy-honey-bear-reader.css handles it instead.
                  if (text && (
                    text.indexOf('.treeItem') > -1 ||
                    text.indexOf('.thumbnail') > -1 ||
                    text.indexOf('#outlineView') > -1 ||
                    text.indexOf('#outlinesView') > -1 ||
                    text.indexOf('#thumbnailView') > -1 ||
                    text.indexOf('#thumbnailsView') > -1 ||
                    text.indexOf('.treeWithDeepNesting') > -1 ||
                    text.indexOf('#viewsManagerContent') > -1
                  )) {
                    viewerCSS += text + '\n';
                  }
                }
              } catch (e) {
                // Cross-origin or access issues, skip
              }
            }
          }

          if (viewerCSS) {
            var style = document.createElement('style');
            style.id = 'pdf-sidebar-styles';
            style.textContent = viewerCSS;
            this._modal._container.appendChild(style);
          } else {
            this._addFallbackStyles();
          }
        } catch (e) {
          this._addFallbackStyles();
        }
      },

      _addFallbackStyles: function() {
        // Basic styles for sidebar content
        var style = document.createElement('style');
        style.id = 'pdf-sidebar-fallback-styles';
        style.textContent = `
          #sidebarContent {
            overflow: auto;
            flex-grow: 1;
            min-height: 0;
          }

          .treeWithDeepNesting {
            list-style: none;
            padding: 0;
            margin: 0;
          }

          .treeItem {
            list-style: none;
          }

          #outlineView .treeItem a {
            display: block;
            padding: 1em 1em 1em 1.2em;
            text-decoration: none;
            color: inherit;
          }

          .thumbnail {
            cursor: pointer;
            display: inline-block;
            margin: 4px;
          }

          #outlineView {
            padding: 4px 4px 0;
          }
        `;
        this._modal._container.appendChild(style);
      },

      _wireOutlineClicks: function(outlineView) {
        var self = this;

        // Find all outline links
        var links = outlineView.querySelectorAll('a');
        links.forEach(function(link) {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();

            // Get the original destination from the link
            var dest = link.getAttribute('href');
            if (!dest || !dest.startsWith('#')) {
              return;
            }

            // Remove the # prefix
            var destName = decodeURIComponent(dest.substring(1));


            // Try to navigate using PDF.js's link service inside the iframe
            try {
              var pdfLinkService = self._reader.PDFViewerApplication.pdfLinkService;

              // Check if it's a simple page reference first
              var pageMatch = destName.match(/^page[=\s]+(\d+)$/i);
              if (pageMatch) {
                var pageNum = parseInt(pageMatch[1], 10);
                self._reader.gotoPage(pageNum);
                self._modal.closeModal();
                return;
              }

              // Check if it's a JSON-encoded destination array (e.g., [{"num":123,"gen":0},{"name":"XYZ"},...])
              var destToUse = destName;
              if (destName.startsWith('[') || destName.startsWith('{')) {
                try {
                  destToUse = JSON.parse(destName);
                } catch (parseErr) {
                  // Keep as string, will try as named destination
                }
              }

              // Navigate using PDF.js link service
              if (pdfLinkService) {
                pdfLinkService.goToDestination(destToUse).then(function() {
                  self._modal.closeModal();
                }).catch(function(err) {
                  // Try alternative: click the original link in the iframe
                  self._clickIframeOutlineItem(link);
                });
              } else {
              }
            } catch (err) {
            }
          });
        });
      },

      _clickIframeOutlineItem: function(clonedLink) {
        // Fallback: find and click the corresponding link inside the iframe
        var self = this;
        try {
          var href = clonedLink.getAttribute('href');
          if (!href) return;

          var iframeDoc = this._reader._iframe.contentDocument;
          var originalLink = iframeDoc.querySelector('a[href="' + href + '"]');

          if (originalLink) {
            originalLink.click();

            // Close modal after a brief delay to allow navigation
            setTimeout(function() {
              self._modal.closeModal();
            }, 300);
          }
        } catch (err) {
        }
      },

      _wireThumbnailClicks: function(thumbnailView) {
        var self = this;

        // Find all thumbnail elements
        var thumbnails = thumbnailView.querySelectorAll('.thumbnail');
        thumbnails.forEach(function(thumbnail) {
          thumbnail.addEventListener('click', function(e) {
            e.preventDefault();

            // pdf.js 6.x uses non-prefixed "page-number" attribute; older versions used "data-page-number"
            var pageNum = parseInt(
              thumbnail.getAttribute('page-number') || thumbnail.getAttribute('data-page-number'),
              10
            );
            if (pageNum) {
              self._reader.gotoPage(pageNum);
              self._modal.closeModal();
            }
          });
        });
      },

      _setupViewButtons: function() {
        var self = this;
        var modal = this._modal._container;
        var sidebarContainer = modal.querySelector('#sidebarContainer');
        var toolbarSidebar = sidebarContainer ? sidebarContainer.querySelector('#toolbarSidebar') : modal.querySelector('#toolbarSidebar');

        if (!toolbarSidebar) {
          return;
        }

        var outlineBtn = toolbarSidebar.querySelector('#viewOutline');
        var thumbnailBtn = toolbarSidebar.querySelector('#viewThumbnail');
        var attachmentsBtn = toolbarSidebar.querySelector('#viewAttachments');

        var outlineView = modal.querySelector('#outlineView');
        var thumbnailView = modal.querySelector('#thumbnailView');
        var attachmentsView = modal.querySelector('#attachmentsView');

        if (outlineBtn) {
          outlineBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (outlineView) outlineView.classList.remove('hidden');
            if (thumbnailView) thumbnailView.classList.add('hidden');
            if (attachmentsView) attachmentsView.classList.add('hidden');
            outlineBtn.classList.add('toggled');
            if (thumbnailBtn) thumbnailBtn.classList.remove('toggled');
            if (attachmentsBtn) attachmentsBtn.classList.remove('toggled');
          });
        }

        if (thumbnailBtn) {
          thumbnailBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (outlineView) outlineView.classList.add('hidden');
            if (thumbnailView) thumbnailView.classList.remove('hidden');
            if (attachmentsView) attachmentsView.classList.add('hidden');
            if (outlineBtn) outlineBtn.classList.remove('toggled');
            thumbnailBtn.classList.add('toggled');
            if (attachmentsBtn) attachmentsBtn.classList.remove('toggled');

            // Render thumbnails directly from the PDF document on first open.
            // The iframe's #viewsManager is display:none so pdf.js's lazy scroll-based
            // renderer never fires — copying innerHTML from it only gives blank images.
            if (!self._thumbnailsRendered) {
              self._thumbnailsRendered = true;
              self._renderThumbnailsDirect(thumbnailView);
            }
          });
        }

        if (attachmentsBtn) {
          attachmentsBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (outlineView) outlineView.classList.add('hidden');
            if (thumbnailView) thumbnailView.classList.add('hidden');
            if (attachmentsView) attachmentsView.classList.remove('hidden');
            if (outlineBtn) outlineBtn.classList.remove('toggled');
            if (thumbnailBtn) thumbnailBtn.classList.remove('toggled');
            attachmentsBtn.classList.add('toggled');
          });
        }
      }
    });

    // Main PDF Reader - Iframe-based
    var PDFIframeReader = cozy.Reader.extend({

      open: function(target, cb) {
        var self = this;
        if ( cb == null ) { cb = function() {}; }

        // Create and insert the iframe into the book container
        this._createIframeContainer();

        this._iframe = document.getElementById('pdf-viewer-iframe');
        this._pdfWindow = null;

        // Build viewer URL with PDF file
        const pdfUrl = '/epubs/<%= @presenter.id %>/file';
        const viewerUrl = new URL('/mozilla-pdf-viewer/web/viewer.html', window.location.origin);
        viewerUrl.searchParams.set('file', pdfUrl);

        // Handle initial page from hash
        const initialHash = window.location.hash;
        if (initialHash) {
          viewerUrl.hash = initialHash.substring(1);
        }

        this._iframe.src = viewerUrl.toString();

        // Install the Hypothesis `downloadComplete` shim as early as possible.
        //
        // The iframe's `load` event fires only after pdf.js's module scripts have
        // finished executing and `initializedPromise` has already resolved. The
        // Hypothesis client (injected into this same-origin iframe as soon as its
        // parent-side MutationObserver sees `enable-annotation`) hangs a callback
        // off `initializedPromise` that reads viewer metadata, and in pdf.js 6.x
        // that callback can fire BEFORE our `load` handler runs. If the shim isn't
        // in place by then, Hypothesis dereferences `app.pdfDocument` while it's
        // still `null` and throws — killing sidebar boot.
        //
        // To close the race, start polling `contentWindow.PDFViewerApplication`
        // right after setting `src` and install the shim the moment it appears.
        // The `load`-handler copy of this shim remains as a belt-and-braces
        // fallback in case this poll somehow misses the window.
        // The parent monograph URL that Hypothesis should attribute annotations to,
        // instead of the raw PDF file download URL (`/epubs/:id/file`) that pdf.js
        // exposes via `PDFViewerApplication.url`. Hypothesis's PDF metadata strategy
        // (pdf-metadata.ts `_getPDFURL()`) reads `app.url` as the PRIMARY URI for
        // every annotation — canonical <link> and citation_* <meta> tags only get
        // added as secondary links, so setting them alone is not enough.
        //
        // We do NOT try to encode the current PDF page in a `#page=N` fragment here:
        // Hypothesis normalises URLs by stripping fragments before storing an
        // annotation (so that annotations on different fragments of the same doc
        // group together), and its PDF-anchoring code records the page separately
        // via pdf.js's page-label API — that's where the "p. 373" tag on each
        // annotation comes from, and it's what powers deep-link-to-page from the
        // sidebar. So capturing window.location.href once at iframe creation time
        // (before updateLocation has appended any hash) is exactly what we want.
        var hypothesisAnnotationUrl = window.location.href.split('#')[0];

        (function() {
          var pollStart = Date.now();
          var pollId = setInterval(function() {
            var win;
            try { win = self._iframe.contentWindow; } catch (e) { return; }
            if (!win) { return; }
            var app = win.PDFViewerApplication;
            if (app) {
              clearInterval(pollId);
              try {
                if (!Object.getOwnPropertyDescriptor(app, 'downloadComplete')) {
                  Object.defineProperty(app, 'downloadComplete', {
                    configurable: true,
                    enumerable: true,
                    get: function() { return !!this.pdfDocument; }
                  });
                }
              } catch (e) { /* non-fatal */ }
              // Redirect Hypothesis's primary annotation URI to the parent monograph
              // page. pdf.js's own download flow uses `_downloadUrl` (not `url`), so
              // overriding `url` with a getter doesn't break the Save/Download button.
              // Defined as configurable+writable so pdf.js's later `setTitleUsingUrl()`
              // assignment silently no-ops on the getter without throwing in strict mode.
              try {
                var existing = Object.getOwnPropertyDescriptor(app, 'url');
                if (!existing || !existing.get) {
                  Object.defineProperty(app, 'url', {
                    configurable: true,
                    enumerable: true,
                    get: function() { return hypothesisAnnotationUrl; },
                    set: function() { /* locked — pdf.js may try to overwrite during open() */ }
                  });
                }
              } catch (e) { /* non-fatal */ }
            } else if (Date.now() - pollStart > 30000) {
              // Give up after 30s — the `load` handler will make its own attempt.
              clearInterval(pollId);
            }
          }, 5);
        })();

        this.annotations = {
          reset: function() { /* NOP */ }
        };

        // Turn off default updateLocation handler
        this.off('updateLocation');

        // Setup location tracking
        this.on('updateLocation', function(location) {
          var tmp_href = window.location.href.split('#');
          var tracking = { cfi: location.start, href: location.href, action: self.tracking.action()};

          var pageMatch = location.start.match(/page=(\d+)/);
          if (pageMatch) {
            var newHash = 'page=' + pageMatch[1];
            tmp_href[1] = newHash;

            var currentHash = window.location.hash.substring(1);
            if (currentHash !== newHash) {
              var context = [{ cfi: location.start }, '', tmp_href.join('#')];
              if ( tracking.action && tracking.action.match(/\/go\/link/) ) {
                history.pushState.apply(history, context);
              } else {
                history.replaceState.apply(history, context);
              }
            }
          }

          if ( location.percentage ) {
            var p = Math.ceil(location.percentage * 100);
            document.title = `${p}% - ${self._original_document_title}`;
          }

          self.fire('trackPageview', tracking)
        });

        // Wait for iframe to load
        this._iframe.addEventListener('load', function() {
          self._pdfWindow = self._iframe.contentWindow;

          // Set --body-bg-color to white inside the iframe AND force single-page
          // (non-spread) layout BEFORE pdf.js renders any pages. Both concerns
          // are handled statically by cozy-iframe-overrides.css, which viewer.html
          // loads via <link rel="stylesheet"> right after viewer.css. That stylesheet
          // is same-origin so it's permitted by the iframe's CSP `style-src 'self'`,
          // whereas the previous JS-appended <style> element was blocked by CSP
          // (no 'unsafe-inline', no nonce). Only non-style DOM (canonical/meta tags
          // for Hypothesis attribution) is still injected here.
          // Shim PDFViewerApplication.downloadComplete for Hypothesis.
          //
          // hypothes.is client's pdf-metadata.ts probes the viewer like this:
          //
          //   if (app.downloadComplete !== undefined) return app.downloadComplete;
          //   await app.pdfDocument.getDownloadInfo();
          //
          // pdf.js 6.1.200 REMOVED the `downloadComplete` field (it was a 5.x thing),
          // so Hypothesis falls into the second branch. But Hypothesis kicks off its
          // metadata read as soon as `PDFViewerApplication.initializedPromise` resolves,
          // and in 6.x that promise resolves BEFORE `open()` is called — meaning
          // `app.pdfDocument` is still `null` at that moment. The `.getDownloadInfo()`
          // dereference then throws `TypeError: Cannot read properties of null`,
          // aborting Hypothesis client bootstrap and leaving the sidebar dead.
          //
          // Restoring `downloadComplete` as a getter puts Hypothesis back on the fast
          // path: it never touches `pdfDocument.getDownloadInfo()`, and its own polling
          // loop (100ms delay while downloadComplete is false) waits us out until the
          // document is actually loaded. Once `pdfDocument` exists in the iframe, pdf.js
          // has resolved getDocument() — which by design happens after full download —
          // so `!!pdfDocument` is a correct proxy for "download complete".
          try {
            var pdfWin = self._iframe.contentWindow;
            if (pdfWin && pdfWin.PDFViewerApplication &&
                !Object.getOwnPropertyDescriptor(pdfWin.PDFViewerApplication, 'downloadComplete')) {
              Object.defineProperty(pdfWin.PDFViewerApplication, 'downloadComplete', {
                configurable: true,
                enumerable: true,
                get: function() { return !!this.pdfDocument; }
              });
            }
            // Fallback copy of the annotation-URL override (see poll above for rationale).
            if (pdfWin && pdfWin.PDFViewerApplication) {
              var existingUrlDesc = Object.getOwnPropertyDescriptor(pdfWin.PDFViewerApplication, 'url');
              if (!existingUrlDesc || !existingUrlDesc.get) {
                Object.defineProperty(pdfWin.PDFViewerApplication, 'url', {
                  configurable: true,
                  enumerable: true,
                  get: function() { return hypothesisAnnotationUrl; },
                  set: function() { /* locked */ }
                });
              }
            }
          } catch (shimErr) {
            // Non-fatal — Hypothesis will still fail its metadata read, but at least
            // the PDF itself keeps working.
          }

          try {
            var iframeDoc = self._iframe.contentDocument || self._iframe.contentWindow.document;
            if (iframeDoc) {

              // Hypothesis (loaded on the parent, propagated into this same-origin
              // iframe via the `enable-annotation` attribute) derives each annotation's
              // URL and title from the *iframe* document's metadata — its HTMLMetadata
              // strategy reads `<link rel="canonical">`, `document.title`, and
              // Highwire/DC `<meta>` tags. Without intervention, annotations get saved
              // against `/mozilla-pdf-viewer/web/viewer.html` with the title
              // "PDF.js viewer". Inject the parent page's canonical URL and title into
              // the iframe head so annotations are attributed to the Fulcrum monograph
              // page instead.
              //
              // Preserve the `#page=…` fragment (kept in sync with the current PDF
              // page by the updateLocation handler above) so each annotation records
              // the page the user was on when they made it. Hypothesis will still
              // group annotations by the fragmentless URL for display, but keeping
              // the fragment on the target URI makes deep-links back to the exact
              // page work when following an annotation.
              try {
                var parentHref = window.location.href;
                var parentTitle = <%= raw @parent_presenter.page_title.to_json %>;

                var canonical = iframeDoc.createElement('link');
                canonical.setAttribute('rel', 'canonical');
                canonical.setAttribute('href', parentHref);
                (iframeDoc.head || iframeDoc.documentElement).appendChild(canonical);

                // Highwire tags — Hypothesis's HTMLMetadata treats these as
                // authoritative when present, so they beat any residual defaults
                // pdf.js might set on document.title later during load.
                var hwTitle = iframeDoc.createElement('meta');
                hwTitle.setAttribute('name', 'citation_title');
                hwTitle.setAttribute('content', parentTitle);
                (iframeDoc.head || iframeDoc.documentElement).appendChild(hwTitle);

                var hwUrl = iframeDoc.createElement('meta');
                hwUrl.setAttribute('name', 'citation_public_url');
                hwUrl.setAttribute('content', parentHref);
                (iframeDoc.head || iframeDoc.documentElement).appendChild(hwUrl);

                iframeDoc.title = parentTitle;
              } catch (metaErr) {
                // Non-fatal — annotations will just fall back to iframe defaults.
              }
            }
          } catch (e) {
            // Cross-origin or access issues — degrade gracefully
          }

          self._setupLoadingProgressBar();
          self._waitForPDFInit(cb);
        });
      },

      // Restore the press-branded download progress bar on the parent page.
      //
      // pdf.js 6.1.200 still uses the #loadingBar element inside the iframe and updates the
      // --progressBar-percent CSS variable on it via viewer.mjs (ProgressBar#_updateBar,
      // ~line 5771). cozy-iframe-overrides.css hides that iframe bar. We create a twin bar
      // on the parent page (styled by app/assets/stylesheets/mozilla-pdf-viewer/
      // cozy-honey-bear-reader.css and coloured per-press via themes.scss's
      // `.helio-loading-bar .progress` rules) and mirror the CSS variable + hidden state
      // over on every mutation. The aria-live #pdfLoadingProgressBar element (declared in
      // this template's <body>) is updated at most every 5s so screen readers get useful
      // progress feedback without being spammed.
      _setupLoadingProgressBar: function() {
        var self = this;

        var iframeDoc;
        try {
          iframeDoc = self._iframe.contentDocument || self._iframe.contentWindow.document;
        } catch (e) { return; }
        if (!iframeDoc) { return; }

        var iframeBar = iframeDoc.getElementById('loadingBar');
        if (!iframeBar) { return; }

        // Insert the parent-page bar once, prepended to cozy's main container.
        var parentBar = document.getElementById('helioLoadingBar');
        if (!parentBar) {
          var host = document.querySelector('.cozy-module-main') || document.getElementById('mainContainer');
          if (!host) { return; }
          parentBar = document.createElement('div');
          parentBar.id = 'helioLoadingBar';
          parentBar.className = 'helio-loading-bar';
          parentBar.setAttribute('aria-hidden', 'true');
          parentBar.innerHTML = '<div class="progress"><div class="glimmer"></div></div>';
          host.insertBefore(parentBar, host.firstChild);
        }

        var announce = document.getElementById('pdfLoadingProgressBar');
        var lastAnnounceTime = 0;

        function sync() {
          // Read the CSS var pdf.js writes on the iframe's #loadingBar and copy it over.
          var pct = iframeBar.style.getPropertyValue('--progressBar-percent') || '0%';
          parentBar.style.setProperty('--progressBar-percent', pct);

          // Mirror hidden / indeterminate state so the bar disappears when pdf.js hides it.
          parentBar.classList.toggle('hidden', iframeBar.classList.contains('hidden'));
          parentBar.classList.toggle('indeterminate', iframeBar.classList.contains('indeterminate'));

          if (!announce) { return; }
          var percentInt = parseInt(pct, 10) || 0;
          var now = Date.now();
          if (!lastAnnounceTime) {
            announce.innerHTML = 'PDF loading started';
            lastAnnounceTime = now;
          } else if (percentInt >= 100) {
            announce.innerHTML = 'PDF loading complete';
          } else if (now - lastAnnounceTime > 5000) {
            announce.innerHTML = pct + ' loaded';
            lastAnnounceTime = now;
          }
        }

        sync();
        var observer = new MutationObserver(sync);
        observer.observe(iframeBar, { attributes: true, attributeFilter: ['style', 'class'] });
      },

      _createIframeContainer: function() {
        // Find the book content container created by cozy-sun-bear
        var bookContainer = document.querySelector('.cozy-module-book-epub');
        if (!bookContainer) {
          // Fallback: create it if it doesn't exist yet
          bookContainer = document.createElement('div');
          bookContainer.className = 'cozy-module-book-epub';
          var mainContainer = document.getElementById('mainContainer');
          if (mainContainer) {
            mainContainer.appendChild(bookContainer);
          }
        }

        // Create iframe structure inside the book container.
        //
        // The `enable-annotation` attribute opts this same-origin iframe in to
        // hypothes.is annotation. The hypothes.is client is loaded on the parent
        // page (see <head> above) and uses a MutationObserver to discover child
        // frames carrying this attribute, injecting its boot script into them so
        // pdf.js's textLayer becomes annotatable. Without the attribute the
        // client only annotates parent-page selections, never the PDF content.
        // See: https://h.readthedocs.io/projects/client/en/latest/publishers/embedding/
        var enableAnnotationAttr = <%== @parent_presenter.use_hypothesis? ? "'enable-annotation '" : "''" %>;
        bookContainer.innerHTML =
          '<div id="viewerContainer" style="width: 100%; height: 100%; position: relative;">' +
            '<iframe ' +
              'id="pdf-viewer-iframe" ' +
              enableAnnotationAttr +
              'src="" ' +
              'style="width: 100%; height: 100%; border: none; display: block;" ' +
              'title="PDF Viewer" ' +
              'allowfullscreen>' +
            '</iframe>' +
          '</div>';
      },

      _waitForPDFInit: function(cb) {
        var self = this;

        // pdf.js 6.1.200 viewer.mjs: PDFViewerApplication.initializedPromise is a public getter
        // (returns _initializedCapability.promise). Await it then open; fall back to polling if
        // the promise is unavailable so we don't regress on unexpected builds.
        var pdfApp = self._pdfWindow.PDFViewerApplication;

        function _setup(pdfApp) {
          self.PDFViewerApplication = pdfApp;
          self.pdfViewer = pdfApp.pdfViewer;

          // Mirror the scale pdf.js restored from its own preference storage back into
          // reader.options.scale so the Preferences dialog's PDFScale fieldset can pre-
          // select the matching radio button when opened. reopen() keeps this in sync
          // thereafter; without this line the dialog always shows "Automatic Zoom".
          if (self.pdfViewer && self.pdfViewer.currentScaleValue) {
            self.options.scale = self.pdfViewer.currentScaleValue;
          }

          // pdf.js 6.1.200 viewer.mjs: pdfLinkService._ignoreDestinationZoom is still a writable
          // underscore-prefixed property (set in PDFLinkService constructor, line ~6450). Setting it
          // to true suppresses zoom-on-destination-navigate (ToC clicks, bookmarks).
          if (pdfApp.pdfLinkService && '_ignoreDestinationZoom' in pdfApp.pdfLinkService) {
            pdfApp.pdfLinkService._ignoreDestinationZoom = true;
          }

          self._setupHistoryTracking();
          self._setupPageChangeEvents();
          self._enforceSinglePageSpread();
          self._loadMetadata(cb);
        }

        if (pdfApp && typeof pdfApp.initializedPromise !== 'undefined') {
          // Preferred: await the public initializedPromise, then wait for a document.
          // initializedPromise resolves after preferences load — not file-size dependent —
          // but the preview server can be slow, so allow 60s for viewer bootstrap.
          var timeoutId = setTimeout(function() {
            console.error("PDF reader: initializedPromise timed out; aborting init");
          }, 60000);

          pdfApp.initializedPromise.then(function() {
            clearTimeout(timeoutId);
            // initializedPromise resolves after preferences are loaded but before open().
            // Poll for pdfDocument (open() is called internally by the viewer URL params).
            // This IS file-size dependent: some Fulcrum PDFs are >1GB and take minutes to
            // download/parse on the preview server, so allow up to 3 minutes.
            var docAttempts = 0;
            var docMaxAttempts = 1800; // 1800 * 100ms = 180s (3 minutes)
            var docInterval = setInterval(function() {
              docAttempts++;
              if (pdfApp.pdfDocument) {
                clearInterval(docInterval);
                _setup(pdfApp);
              } else if (docAttempts >= docMaxAttempts) {
                clearInterval(docInterval);
                console.error("PDF reader: document did not load after initializedPromise resolved (waited " + (docMaxAttempts / 10) + "s)");
              }
            }, 100);
          }).catch(function(err) {
            clearTimeout(timeoutId);
            console.error("PDF reader: initializedPromise rejected:", err);
          });

        } else {
          // Fallback: poll PDFViewerApplication.pdfDocument (same as 5.x behavior).
          // Matches the primary branch: allow up to 3 minutes for large (>1GB) PDFs.
          var attempts = 0;
          var maxAttempts = 1800; // 1800 * 100ms = 180s (3 minutes)
          var checkInterval = setInterval(function() {
            attempts++;
            try {
              var app = self._pdfWindow.PDFViewerApplication;
              if (app && app.pdfDocument) {
                clearInterval(checkInterval);
                _setup(app);
              } else if (attempts >= maxAttempts) {
                clearInterval(checkInterval);
                console.error("PDF reader: PDF failed to initialize");
              }
            } catch (e) {
              // Not ready yet, keep trying
            }
          }, 100);
        }
      },

      _setupHistoryTracking: function() {
        var self = this;
        var pdfHistory = this.PDFViewerApplication.pdfLinkService.pdfHistory;

        if (!pdfHistory) {
          // pdfHistory can be null when the viewer is embedded — degrade gracefully.
          return;
        }

        // Wrap push() to track ToC/bookmark clicks (best-effort; sealed/renamed degrades gracefully)
        if (typeof pdfHistory.push === 'function') {
          var originalPush = pdfHistory.push.bind(pdfHistory);
          pdfHistory.push = function(params) {
            self.tracking.action('contents/go/link');
            return originalPush(params);
          };
        }

        // Wrap pushPage() to track thumbnail clicks
        if (typeof pdfHistory.pushPage === 'function') {
          var originalPushPage = pdfHistory.pushPage.bind(pdfHistory);
          pdfHistory.pushPage = function(pageNumber) {
            self.tracking.action('contents/go/link');
            return originalPushPage(pageNumber);
          };
        }
      },

      // Belt to the CSS braces in _createIframeContainer's load handler: lock
      // pdfViewer.spreadMode and pdfViewer.scrollMode to 0 (single-page,
      // vertical scroll) so user keyboard shortcuts (Ctrl+Alt+1/2/3 for spread,
      // Ctrl+Alt+P/H/V/W for scroll) can't put pdf.js into a layout state that
      // disagrees with the visual single-column we force via CSS.
      _enforceSinglePageSpread: function() {
        var viewer = this.pdfViewer;
        if (!viewer) return;

        function lockProp(name, value) {
          try {
            try { viewer[name] = value; } catch (e) { /* triggers initial layout */ }
            Object.defineProperty(viewer, name, {
              configurable: true,
              enumerable: true,
              get: function() { return value; },
              set: function() { /* locked */ }
            });
          } catch (e) { /* defensive */ }
        }

        lockProp('spreadMode', 0); // PDFJS SpreadMode.NONE
        lockProp('scrollMode', 0); // PDFJS ScrollMode.VERTICAL
      },

      _setupPageChangeEvents: function() {
        var self = this;
        var pdfInitialized = false;

        // Wait a moment for initial page to settle
        setTimeout(function() {
          pdfInitialized = true;
        }, 500);

        // Re-centre #viewerContainer whenever the zoom level changes.
        // pdf.js sets a fixed pixel width on #viewer on each scale change and does
        // not reset scrollLeft, so after zooming in and back out the viewport can
        // appear off-centre. Resetting scrollLeft here keeps it anchored at 0.
        this.PDFViewerApplication.eventBus.on('scalechanging', function(evt) {
          try {
            var viewerContainer = self._pdfWindow.document.getElementById('viewerContainer');
            if (viewerContainer) {
              viewerContainer.scrollLeft = 0;
            }
          } catch (e) { /* cross-origin guard */ }
        });

        this.PDFViewerApplication.eventBus.on('pagechanging', function(evt) {
          var pageNumber = evt.pageNumber;

          if (pdfInitialized) {
            self.fire('relocated', { start: pageNumber });
            self.fire('updateLocation', {
              start: 'epubcfi(page=' + pageNumber + ')',
              href: self.options.href + '#page=' + pageNumber,
              percentage: ( pageNumber / self.PDFViewerApplication.pagesCount )
            });
          }
        });

        // Handle manual hash changes
        window.addEventListener('hashchange', function(e) {
          var newHash = window.location.hash;
          if (newHash && newHash.indexOf('#page=') === 0) {
            var pageMatch = newHash.match(/#page=(\d+)/);
            if (pageMatch) {
              var targetPage = parseInt(pageMatch[1], 10);
              if (self.pdfViewer && self.pdfViewer.currentPageNumber !== targetPage) {
                self.pdfViewer.currentPageNumber = targetPage;
              }
            }
          }
        });
      },

      _loadMetadata: function(cb) {
        var self = this;

        this.PDFViewerApplication.pdfDocument.getMetadata().then(function(data) {
          var metadata = {};
          metadata.layout = 'pdf';

          if ( data.metadata ) {
            var _hasMeta = typeof data.metadata.has === 'function';
            var _getMeta = typeof data.metadata.get === 'function';
            var _hasTitle = _hasMeta ? data.metadata.has("dc:title") : Object.prototype.hasOwnProperty.call(data.metadata, "dc:title");
            var _hasAuthor = _hasMeta ? data.metadata.has("dc:author") : Object.prototype.hasOwnProperty.call(data.metadata, "dc:author");
            if ( _hasTitle ) {
              metadata.title = _getMeta ? data.metadata.get("dc:title") : data.metadata["dc:title"];
            }
            if ( _hasAuthor ) {
              metadata.author = _getMeta ? data.metadata.get("dc:author") : data.metadata["dc:author"];
            }
            metadata.noid = '<%= @noid %>';
            metadata.press_subdomain = '<%= @subdomain %>';
          }
          self.metadata = metadata;

          self.fire("updateTitle", self.metadata);
          self.fire('updateContents', {});

          self.locations = { total: self.PDFViewerApplication.pagesCount };
          self.locations.locationFromCfi = function(pageNum) {
            return pageNum;
          };
          self.locations.percentageFromCfi = function(pageNum) {
            return ( pageNum / self.locations.total );
          };
          self.locations.cfiFromPercentage = function(percent) {
            var pageNum = Math.round(self.locations.total * percent);
            if ( pageNum < 1 ) { pageNum = 1; }
            if ( pageNum > this.total ) { pageNum = this.total; }
            return { start: pageNum };
          };

          self.fire('updateLocations',  self.locations);
          self.fire('relocated', self.currentLocation());
          self._disableBookLoader();

          self.fire("ready");


          cb();
        });
      },

      currentLocation: function() {
        return { start: { cfi: this.PDFViewerApplication.page } };
      },

      _scroll: function(delta) {
        if (!this.PDFViewerApplication) return;

        switch(delta) {
          case 'PREV':
            this.PDFViewerApplication.page--;
            break;
          case 'NEXT':
            this.PDFViewerApplication.page++;
            break;
          case 'HOME':
            this.PDFViewerApplication.page = 1;
            break;
          case 'END':
            this.PDFViewerApplication.page = this.PDFViewerApplication.pagesCount;
            break;
        }
      },

      gotoPage: function(value) {
        var pageNum;
        if ( typeof(value) == "string" ) {
          if ( value.indexOf('epubcfi') > -1 ) {
            pageNum = value.replace('epubcfi(page=','').replace(')', '');
          } else {
            pageNum = value.replace('page=','');
          }
        } else if ( typeof(value) == 'object' && value.start ) {
          pageNum = value.start;
        } else {
          pageNum = value;
        }

        if (this.pdfViewer) {
          this.pdfViewer.currentPageNumber = parseInt(pageNum, 10);
        }
      },

      reopen: function(options) {
        if (options.scale && this.pdfViewer) {
          this.options.scale = options.scale;
          this.pdfViewer.currentScaleValue = options.scale;
        }
      },

      // Rotate pages clockwise
      rotateCW: function() {
        if (this.pdfViewer) {
          this.pdfViewer.pagesRotation += 90;
        }
      },

      // Rotate pages counter-clockwise
      rotateCCW: function() {
        if (this.pdfViewer) {
          this.pdfViewer.pagesRotation -= 90;
        }
      },

      EOT: true
    });

    // Initialize reader
    var reader = new PDFIframeReader('mainContainer', {
      href: '/epubs/<%= @presenter.id %>',
      download_links: <%= @ebook_download_presenter.csb_download_links.to_json.html_safe %>,
      metadata: {
        title: '<%= raw escape_javascript(@parent_presenter.page_title) %>'
      }
    });

    // Add all cozy-sun-bear controls
    <%= render partial: "cozy_controls_top", formats: [:js], presenter: @presenter, parent_presenter: @parent_presenter %>

    <%= render partial: "cozy_controls_bottom", formats: [:js], presenter: @presenter, parent_presenter: @parent_presenter %>

    <% if @parent_presenter.use_hypothesis? %>
      // Annotation widget initialization.
      //
      // Safe to create and add immediately even before the Hypothesis client boots:
      // AnnotationTool forwards clicks to the server-rendered #hypothesisProxyTrigger
      // (which Hypothesis binds to reliably), so there is no ordering dependency on
      // Hypothesis boot / cozy control insertion.
      var annotation_tool = new AnnotationTool({
        region: 'top.toolbar.left'
      });
      annotation_tool.addTo(reader);
    <% end %>

    // Start reader
    reader.start();

    // Wire up buttons that need to communicate with iframe
    function wireUpIframeControls() {
      // Rotation button
      var rotateButton = document.getElementById('pageRotateCw');
      if (rotateButton && !rotateButton.dataset.wiredUp) {
        rotateButton.dataset.wiredUp = 'true';
        rotateButton.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          reader.rotateCW();
        });
      }

      // Previous page button - try multiple selectors
      var previousButton = document.querySelector('.cozy-control-previous') ||
                          document.querySelector('[data-control="previous"]') ||
                          document.querySelector('.cozy-control.previous');

      if (previousButton && !previousButton.dataset.wiredUp) {
        previousButton.dataset.wiredUp = 'true';
        previousButton.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          if (reader.PDFViewerApplication) {
            reader._scroll('PREV');
          }
        }, true);
      }

      // Next page button - try multiple selectors
      var nextButton = document.querySelector('.cozy-control-next') ||
                      document.querySelector('[data-control="next"]') ||
                      document.querySelector('.cozy-control.next');

      if (nextButton && !nextButton.dataset.wiredUp) {
        nextButton.dataset.wiredUp = 'true';
        nextButton.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          if (reader.PDFViewerApplication) {
            reader._scroll('NEXT');
          }
        }, true);
      }
    }

    wireUpIframeControls();
    setTimeout(wireUpIframeControls, 500);
    setTimeout(wireUpIframeControls, 1000);
    setTimeout(wireUpIframeControls, 2000);

    reader.on('ready', function() {
      wireUpIframeControls();
    });
  </script>

  <%= render 'shared/ga' %>
<% end %>
<%= render template: 'layouts/mozilla-pdf-viewer' %>
















