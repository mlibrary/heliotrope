<head>
  <doi_batch_id>
    <!-- DOI BATCH ID -->
  </doi_batch_id>
  <timestamp>
    <!-- TIMESTAMP -->
  </timestamp>
  <depositor>
    <depositor_name>scpo</depositor_name>
    <email_address>mpub.xref@gmail.com</email_address>
  </depositor>
  <registrant>MPublishing</registrant>
</head>
<body>
  <book book_type="">
    <book_metadata language="en">
      <contributors>
        <!-- CONTRIBUTORS -->
      </contributors>
      <titles>
        <title>
          <!-- TITLE -->
        </title>
      </titles>
      <publication_date>
        <!-- PUBLICATION_DATE -->
      </publication_date>
      <!-- PRINT ISBN -->
      <!-- ELECTRONIC ISBN -->
      <publisher>
        <publisher_name>
          <!-- PUBLISHER_NAME -->
        </publisher_name>
      </publisher>
      <doi_data>
        <doi>
          <!-- DOI -->
        </doi>
        <resource>
          <!-- RESOURCE -->
        </resource>
      </doi_data>
    </book_metadata>
  </book>
